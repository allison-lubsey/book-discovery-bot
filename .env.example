# ─── Required ────────────────────────────────────────────────────────────────

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Groq API key (free at console.groq.com)
GROQ_API_KEY=

# Anthropic API key — used for screenshot/vision extraction (claude-haiku-4-5-20251001)
# Get one at console.anthropic.com
ANTHROPIC_API_KEY=

# Notion integration token (starts with "secret_")
NOTION_API_KEY=

# The 32-char ID from your Notion database URL
NOTION_DATABASE_ID=

# Your Ntfy topic name (pick any unique string, e.g. "allison-books-xyz")
NTFY_TOPIC=

# ─── Optional ────────────────────────────────────────────────────────────────

# Restrict the bot to only respond to your Telegram user ID
# Find yours by messaging @userinfobot on Telegram
# Leave blank to allow anyone who messages the bot
TELEGRAM_USER_ID=

# Google Books API key (free, improves rate limits)
# Get one at console.cloud.google.com → Books API
GOOGLE_BOOKS_API_KEY=

# Path to a Netscape cookies.txt file exported from your browser while logged in to TikTok.
# This lets yt-dlp fetch TikTok comments from server/datacenter IPs (which TikTok blocks otherwise).
# How to export: install the "Get cookies.txt LOCALLY" Chrome extension, log in to TikTok,
# click the extension, export → save as cookies.txt, upload it to your Render instance.
# On Render: add as a Secret File at /etc/secrets/cookies.txt and set:
# TIKTOK_COOKIES_FILE=/etc/secrets/cookies.txt
TIKTOK_COOKIES_FILE=

# Set automatically by Render – only needed for local webhook testing with ngrok
# RENDER_EXTERNAL_URL=https://your-app.onrender.com
